{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "issueId",
      "type": "promptString",
      "description": "Linear issue identifier",
      "default": "NIA-"
    },
    {
      "id": "branchDescription",
      "type": "promptString",
      "description": "Short kebab-case branch description"
    }
  ],
  "tasks": [
    {
      "label": "Workflow: Start issue branch",
      "type": "process",
      "command": "rtk",
      "args": ["run", "git fetch origin main && git switch --no-track -c '${input:issueId}/${input:branchDescription}' origin/main"],
      "problemMatcher": []
    },
    {
      "label": "Workflow: Open current Linear issue",
      "type": "process",
      "command": "rtk",
      "args": [
        "run",
        "issue=$(git branch --show-current | sed -E 's#^([^/]+).*#\\1#'); test -n \"$issue\" && open \"https://linear.app/niama/issue/$issue\""
      ],
      "problemMatcher": []
    },
    {
      "label": "Workflow: Test",
      "type": "process",
      "command": "rtk",
      "args": ["test", "bun", "run", "test"],
      "problemMatcher": []
    },
    {
      "label": "Workflow: Typecheck",
      "type": "process",
      "command": "rtk",
      "args": ["proxy", "bun", "run", "typecheck"],
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Workflow: Quality",
      "type": "process",
      "command": "rtk",
      "args": ["proxy", "bun", "run", "check"],
      "problemMatcher": []
    },
    {
      "label": "Workflow: Build",
      "type": "process",
      "command": "rtk",
      "args": ["proxy", "bun", "run", "build"],
      "problemMatcher": []
    },
    {
      "label": "Workflow: Diff check",
      "type": "process",
      "command": "rtk",
      "args": ["git", "diff", "--check"],
      "problemMatcher": []
    },
    {
      "label": "Workflow: Verify all",
      "dependsOrder": "sequence",
      "dependsOn": ["Workflow: Test", "Workflow: Typecheck", "Workflow: Quality", "Workflow: Build", "Workflow: Diff check"],
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Workflow: Open current PR",
      "type": "process",
      "command": "rtk",
      "args": ["gh", "pr", "view", "--web"],
      "problemMatcher": []
    },
    {
      "label": "Workflow: Watch current PR checks",
      "type": "process",
      "command": "rtk",
      "args": ["gh", "pr", "checks", "--watch", "--interval", "10"],
      "problemMatcher": []
    }
  ]
}
