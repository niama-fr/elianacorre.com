{
  "name": "@ec/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "oxfmt --check . && oxlint .",
    "dev": "turbo dev",
    "fix": "oxfmt --write . && oxlint --fix .",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "oxlint-tsgolint": "7.0.2001",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "ultracite": "7.9.4"
  },
  "packageManager": "bun@1.3.10"
}
