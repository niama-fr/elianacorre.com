{
  "name": "@ec/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "oxfmt --check . && oxlint .",
    "dev": "turbo dev",
    "fix": "oxfmt --write . && oxlint --fix .",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.10"
}
