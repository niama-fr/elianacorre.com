{
  "name": "@ec/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "oxfmt --check . && oxlint .",
    "dev": "turbo dev",
    "fix": "oxfmt --write . && oxlint --fix .",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "ultracite": "7.9.3"
  },
  "packageManager": "bun@1.3.10",
  "patchedDependencies": {
    "@niama/loops@0.2.0": "patches/@niama%2Floops@0.2.0.patch"
  }
}
