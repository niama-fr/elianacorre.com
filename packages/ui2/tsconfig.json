{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@domain/*": ["../domain/src/*"],
      "@kobalte2/*": ["../kobalte2/src/*"],
      "@solid-primitives2/*": ["../solid-primitives2/src/*"],
      "@ui2/*": ["./src/*"],
      "@unpic-solid2/*": ["../unpic-solid2/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
