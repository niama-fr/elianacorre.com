{
  "$schema": "https://v2-9-15.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "check": {},
    "dev": { "cache": false, "persistent": true },
    "fix": {
      "cache": false
    },
    "test": {},
    "typecheck": {}
  }
}
